{
  "name": "codrox",
  "version": "0.5.9",
  "description": "Codrox — AI-native development environment",
  "main": "./out/main/index.js",
  "author": "dzhyranov",
  "license": "MIT",
  "homepage": "https://github.com/vdzhyranov/codrox-app#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vdzhyranov/codrox-app.git"
  },
  "bugs": {
    "url": "https://github.com/vdzhyranov/codrox-app/issues"
  },
  "keywords": [
    "electron",
    "ai",
    "development-environment",
    "claude",
    "agent-orchestration",
    "git-worktree",
    "typescript",
    "react",
    "ide",
    "codrox"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "electron-rebuild",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.codrox.app",
    "productName": "Codrox",
    "directories": {
      "buildResources": "resources"
    },
    "asarUnpack": [
      "out/main/mcp-server.js",
      "node_modules/@modelcontextprotocol/**",
      "node_modules/zod/**",
      "node_modules/zod-to-json-schema/**",
      "node_modules/ajv/**",
      "node_modules/ajv-formats/**",
      "node_modules/bindings/**",
      "node_modules/fast-deep-equal/**",
      "node_modules/fast-json-stable-stringify/**",
      "node_modules/fast-uri/**",
      "node_modules/file-uri-to-path/**",
      "node_modules/json-schema-traverse/**",
      "node_modules/uri-js/**"
    ],
    "files": [
      "!**/.{idea,git,cache,output,temp}/**",
      "!**/{.editorconfig,.eslintignore,.eslintrc.cjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}/**",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.env,secrets.dart",
      "!{.npmrc,.nvmrc,.node-version}",
      "!{tsconfig.json,tsconfig.*.json,electron.vite.config.*,vite.config.*}",
      "!{karma.conf.js,.babelrc,.babelrc.js,jest.config.js,.mocharc.yml}",
      "!src/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.inherit.plist"
    },
    "extraResources": [
      {
        "from": "resources/claude-runtime",
        "to": "claude-runtime",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@parcel/watcher": "^2.5.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "codemirror": "^6.0.2",
    "marked": "^17.0.6",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simple-git": "^3.33.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
