{
  "name": "codrox",
  "version": "0.1.14",
  "description": "Codrox — AI-native development environment",
  "main": "./out/main/index.js",
  "bin": {
    "codrox": "./bin/codrox.js"
  },
  "author": "dzhyranov",
  "homepage": ".",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "npx @electron/rebuild",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.codrox.app",
    "productName": "Codrox",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "!**/.{idea,git,cache,output,temp}/**",
      "!**/{.editorconfig,.eslintignore,.eslintrc.cjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}/**",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.env,secrets.dart",
      "!{.npmrc,.nvmrc,.node-version}",
      "!{tsconfig.json,tsconfig.*.json,electron.vite.config.*,vite.config.*}",
      "!{karma.conf.js,.babelrc,.babelrc.js,jest.config.js,.mocharc.yml}",
      "!src/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "vdzhyranov",
      "repo": "codrox-app",
      "private": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.inherit.plist"
    }
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@parcel/watcher": "^2.5.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "codemirror": "^6.0.2",
    "electron": "^41.1.1",
    "marked": "^17.0.6",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simple-git": "^3.33.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
