# Codrox-managed default zsh config
#
# Created once per workspace. Edit freely — Codrox will NOT overwrite this file.
# To restore the default: delete this file; Codrox regenerates it on next launch.

# ---- claude isolation ----
# Scope the fake $HOME only to the claude process so that all other tools
# (gh, git, npm, …) use the real user home without any extra configuration.
if [ -n "$CODROX_WORKSPACE_HOME" ]; then
  claude() { HOME="$CODROX_WORKSPACE_HOME" command claude "$@"; }
fi

# ---- oh-my-zsh ----
if [ -d "$HOME/.oh-my-zsh" ]; then
  export ZSH="$HOME/.oh-my-zsh"
  ZSH_THEME="robbyrussell"
  plugins=(
    alias-finder
    history-substring-search
    aws
    sudo
    vscode
    git-auto-fetch
    yarn
    npm
    git
    brew
    encode64
    docker
    zsh-autosuggestions
    zsh-syntax-highlighting
    z
  )
  source "$ZSH/oh-my-zsh.sh"
fi

# ---- node / nvm ----
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"

# ---- python / pyenv ----
export PYENV_ROOT="$HOME/.pyenv"
[ -d "$PYENV_ROOT/bin" ] && export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init --path)"
  eval "$(pyenv init -)"
fi

# ---- homebrew ----
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# ---- local bins ----
[ -d "$HOME/.local/bin" ] && export PATH="$HOME/.local/bin:$PATH"

# ---- user customizations ----
# Add aliases, secrets, project-specific PATH, etc. below.
# Tip: keep API keys in a chmod 600 file like ~/.zsh_secrets and source it here.
